      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="titulo" parent="1" style="text;html=1;strokeColor=#2D7600;fillColor=#60a917;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;fontColor=#ffffff;" value="Arquitectura del Sistema TechStore" vertex="1">
          <mxGeometry height="40" width="700" x="350" y="20" as="geometry" />
        </mxCell>
        <mxCell id="caso" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1E3A8A;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:15px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#1E3A8A;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;📌 CASO: TechStore&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 16px;line-height:1.7;font-size:12px;&quot;&gt;&lt;b&gt;Tienda online&lt;/b&gt; de productos electrónicos&lt;br&gt;&lt;br&gt;&lt;b&gt;Productos:&lt;/b&gt; smartphones, laptops, tabletas, accesorios&lt;br&gt;&lt;b&gt;Necesidades:&lt;/b&gt; gestión de inventario, transacciones de clientes y datos de usuarios&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="700" x="350" y="89" as="geometry" />
        </mxCell>
        <mxCell id="cliente" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1E40AF;strokeWidth=2;align=center;verticalAlign=top;fontSize=13;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:15px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#1E40AF;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;👤 CLIENTE / USUARIO&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.6;&quot;&gt;• Navega catálogo de productos&lt;br&gt;• Registra cuenta&lt;br&gt;• Inicia sesión&lt;br&gt;• Compra productos&lt;br&gt;• Realiza pagos&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="400" x="500" y="261" as="geometry" />
        </mxCell>
        <mxCell id="frontend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#047857;strokeWidth=2;align=center;verticalAlign=top;fontSize=13;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:15px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#047857;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;🖥️ FRONTEND WEB (Container)&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.6;&quot;&gt;&lt;b&gt;Tecnologías:&lt;/b&gt; HTML / CSS / JavaScript&lt;br&gt;&lt;br&gt;&lt;b&gt;Funciones:&lt;/b&gt;&lt;br&gt;• Interfaz gráfica&lt;br&gt;• Formularios de registro/login&lt;br&gt;• Carrito de compras&lt;br&gt;• Catálogo de productos&lt;/div&gt;" vertex="1">
          <mxGeometry height="202" width="400" x="500" y="478" as="geometry" />
        </mxCell>
        <mxCell id="backend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FED7AA;strokeColor=#C2410C;strokeWidth=2;align=center;verticalAlign=top;fontSize=13;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:15px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#C2410C;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;⚙️ BACKEND APPLICATION (Container)&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.6;&quot;&gt;&lt;b&gt;Tecnologías:&lt;/b&gt; Node.js / Express&lt;br&gt;&lt;br&gt;&lt;b&gt;Funciones:&lt;/b&gt;&lt;br&gt;• Lógica de negocio&lt;br&gt;• Validación backend (tipos, rangos, formato)&lt;br&gt;• Gestión de usuarios e inventario&lt;br&gt;• Gestión de pagos&lt;br&gt;• Consultas parametrizadas (anti-SQLi)&lt;br&gt;• Control de autenticación y roles&lt;br&gt;• Manejo de transacciones ACID&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="440" x="480" y="741" as="geometry" />
        </mxCell>
        <mxCell id="auth" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECDD3;strokeColor=#9F1239;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:14px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#9F1239;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;🔐 AUTENTICACIÓN&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.6;&quot;&gt;• Login seguro&lt;br&gt;• Hash bcrypt / argon2&lt;br&gt;• Tokens JWT / Sesiones&lt;br&gt;• Control de roles&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="280" x="120" y="860" as="geometry" />
        </mxCell>
        <mxCell id="pagos" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECDD3;strokeColor=#9F1239;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:14px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#9F1239;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;💳 PASARELA DE PAGOS&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.6;&quot;&gt;• Validación de pagos&lt;br&gt;• Confirmación transacción&lt;br&gt;• Cifrado SSL/TLS&lt;br&gt;• Cumplimiento PCI-DSS&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="280" x="1000" y="860" as="geometry" />
        </mxCell>
        <mxCell id="bd" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;align=center;verticalAlign=middle;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:16px;font-weight:bold;color:#5B21B6;margin-bottom:4px;&quot;&gt;🗄️ BASE DE DATOS SQL&lt;/div&gt;&lt;div style=&quot;font-size:13px;font-weight:bold;color:#7C3AED;margin-bottom:6px;&quot;&gt;PostgreSQL / MySQL&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 24px;line-height:1.5;font-size:11px;&quot;&gt;&lt;b&gt;Justificación:&lt;/b&gt;&lt;br&gt;✓ Datos estructurados con relaciones&lt;br&gt;✓ Transacciones ACID (críticas en pagos)&lt;br&gt;✓ Consistencia fuerte de stock e inventario&lt;br&gt;✓ Integridad referencial garantizada&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="440" x="480" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="tabla_users" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:13px;font-weight:bold;color:#FFFFFF;padding:5px;background-color:#B45309;border-radius:4px 4px 0 0;margin:-8px -8px 6px -8px;&quot;&gt;📋 USERS&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.5;font-family:monospace;font-size:10px;&quot;&gt;🔑 id (PK)&lt;br&gt;👤 nombre&lt;br&gt;✉️ email&lt;br&gt;🔒 password_hash&lt;br&gt;👥 rol&lt;br&gt;📅 fecha_registro&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="280" x="80" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="tabla_products" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:13px;font-weight:bold;color:#FFFFFF;padding:5px;background-color:#B45309;border-radius:4px 4px 0 0;margin:-8px -8px 6px -8px;&quot;&gt;📦 PRODUCTS&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.5;font-family:monospace;font-size:10px;&quot;&gt;🔑 id (PK)&lt;br&gt;🏷️ nombre&lt;br&gt;📝 descripcion&lt;br&gt;💰 precio&lt;br&gt;📊 stock&lt;br&gt;🗂️ categoria&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="280" x="400" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="tabla_orders" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:13px;font-weight:bold;color:#FFFFFF;padding:5px;background-color:#B45309;border-radius:4px 4px 0 0;margin:-8px -8px 6px -8px;&quot;&gt;🛒 ORDERS&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.5;font-family:monospace;font-size:10px;&quot;&gt;🔑 id (PK)&lt;br&gt;👤 user_id (FK)&lt;br&gt;💵 total&lt;br&gt;📅 fecha&lt;br&gt;✅ estado&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="280" x="720" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="tabla_items" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:13px;font-weight:bold;color:#FFFFFF;padding:5px;background-color:#B45309;border-radius:4px 4px 0 0;margin:-8px -8px 6px -8px;&quot;&gt;📑 ORDER_ITEMS&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.5;font-family:monospace;font-size:10px;&quot;&gt;🔑 id (PK)&lt;br&gt;🛒 order_id (FK)&lt;br&gt;📦 product_id (FK)&lt;br&gt;🔢 cantidad&lt;br&gt;💰 subtotal&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="280" x="1040" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="justif" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;strokeWidth=2;align=center;verticalAlign=top;fontSize=11;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:14px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#0F766E;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;⚖️ JUSTIFICACIÓN: ¿Por qué SQL y no NoSQL?&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.7;font-size:11px;&quot;&gt;&lt;b&gt;Requerimiento TechStore → Razón SQL&lt;/b&gt;&lt;br&gt;💳 Pagos y transacciones → SQL garantiza &lt;b&gt;ACID&lt;/b&gt;&lt;br&gt;🔗 Relaciones (User-Order-Product) → SQL es &lt;b&gt;relacional&lt;/b&gt;&lt;br&gt;📊 Stock e inventario → SQL evita anomalías de concurrencia&lt;br&gt;📈 Reportes (ventas, top productos) → JOINs nativos&lt;br&gt;📋 Datos estructurados → Esquema fijo confiable&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#6B7280;&quot;&gt;NoSQL sería útil solo para logs o búsquedas, pero NO para transacciones financieras.&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="660" x="40" y="1540" as="geometry" />
        </mxCell>
        <mxCell id="riesgos" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;strokeWidth=2;align=center;verticalAlign=top;fontSize=11;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:14px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#DC2626;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;⚠️ RIESGOS DE SEGURIDAD IDENTIFICADOS&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 12px;line-height:1.7;font-size:11px;&quot;&gt;💉 &lt;b&gt;SQL Injection&lt;/b&gt; — manipulación de consultas&lt;br&gt;💸 &lt;b&gt;Fraude en pagos&lt;/b&gt; — datos de tarjeta robados&lt;br&gt;🔓 &lt;b&gt;Robo de credenciales&lt;/b&gt; — passwords expuestos&lt;br&gt;🕵️ &lt;b&gt;Man-in-the-Middle (MITM)&lt;/b&gt; — interceptación&lt;br&gt;⚡ &lt;b&gt;XSS&lt;/b&gt; — inyección de scripts en el frontend&lt;br&gt;🎭 &lt;b&gt;CSRF&lt;/b&gt; — peticiones falsificadas&lt;br&gt;🚫 &lt;b&gt;Acceso no autorizado&lt;/b&gt; — escalación de privilegios&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="640" x="720" y="1540" as="geometry" />
        </mxCell>
        <mxCell id="medidas" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#374151;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:15px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#374151;border-radius:4px 4px 0 0;margin:-8px -8px 10px -8px;&quot;&gt;🛡️ MEDIDAS DE SEGURIDAD (mapeadas a riesgos)&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 20px;line-height:1.8;font-size:12px;&quot;&gt;💉 SQL Injection &amp;nbsp;→&amp;nbsp; ✅ &lt;b&gt;Consultas parametrizadas&lt;/b&gt; (prepared statements) + validación backend&lt;br&gt;💸 Fraude en pagos &amp;nbsp;→&amp;nbsp; ✅ Pasarela &lt;b&gt;PCI-DSS&lt;/b&gt; + tokenización + verificación 3DS&lt;br&gt;🔓 Robo de credenciales &amp;nbsp;→&amp;nbsp; ✅ &lt;b&gt;Hash bcrypt/argon2&lt;/b&gt; + salt + política de contraseñas robustas&lt;br&gt;🕵️ MITM &amp;nbsp;→&amp;nbsp; ✅ &lt;b&gt;HTTPS / SSL/TLS&lt;/b&gt; obligatorio en toda la comunicación&lt;br&gt;⚡ XSS &amp;nbsp;→&amp;nbsp; ✅ Sanitización de inputs + Content Security Policy (CSP)&lt;br&gt;🎭 CSRF &amp;nbsp;→&amp;nbsp; ✅ Tokens CSRF + validación de origen&lt;br&gt;🚫 Acceso no autorizado &amp;nbsp;→&amp;nbsp; ✅ Autenticación &lt;b&gt;JWT&lt;/b&gt; + control de roles vía &lt;b&gt;DCL (GRANT/REVOKE)&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="1320" x="40" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="sep_sql" parent="1" style="text;html=1;strokeColor=#2D7600;fillColor=#60a917;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#ffffff;" value="📝 INSTRUCCIONES SQL APLICADAS A TECHSTORE" vertex="1">
          <mxGeometry height="40" width="700" x="350" y="2060" as="geometry" />
        </mxCell>
        <mxCell id="ddl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFFAFE;strokeColor=#0E7490;strokeWidth=2;align=center;verticalAlign=top;fontSize=11;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:16px;font-weight:bold;color:#FFFFFF;padding:8px;background-color:#0E7490;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;DDL&lt;/div&gt;&lt;div style=&quot;font-size:10px;color:#0E7490;font-style:italic;margin-bottom:6px;&quot;&gt;Data Definition&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 8px;font-family:monospace;font-size:9px;line-height:1.5;&quot;&gt;&lt;b&gt;CREATE TABLE&lt;/b&gt; products (...)&lt;br&gt;&lt;b&gt;ALTER TABLE&lt;/b&gt; products ADD descuento&lt;br&gt;&lt;b&gt;DROP TABLE&lt;/b&gt; tmp_carrito&lt;br&gt;&lt;br&gt;&lt;i&gt;Crea estructura: tablas, índices, claves&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="320" x="40" y="2120" as="geometry" />
        </mxCell>
        <mxCell id="dml" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFFAFE;strokeColor=#0E7490;strokeWidth=2;align=center;verticalAlign=top;fontSize=11;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:16px;font-weight:bold;color:#FFFFFF;padding:8px;background-color:#0E7490;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;DML&lt;/div&gt;&lt;div style=&quot;font-size:10px;color:#0E7490;font-style:italic;margin-bottom:6px;&quot;&gt;Data Manipulation&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 8px;font-family:monospace;font-size:9px;line-height:1.5;&quot;&gt;&lt;b&gt;INSERT INTO&lt;/b&gt; orders (user_id, total)&lt;br&gt;&lt;b&gt;UPDATE&lt;/b&gt; products SET stock = stock-1&lt;br&gt;&lt;b&gt;DELETE FROM&lt;/b&gt; carrito WHERE user_id=?&lt;br&gt;&lt;b&gt;SELECT&lt;/b&gt; * FROM products WHERE cat=?&lt;br&gt;&lt;br&gt;&lt;i&gt;Manipula datos: registrar compra, actualizar stock&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="320" x="380" y="2120" as="geometry" />
        </mxCell>
        <mxCell id="dcl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFFAFE;strokeColor=#0E7490;strokeWidth=2;align=center;verticalAlign=top;fontSize=11;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:16px;font-weight:bold;color:#FFFFFF;padding:8px;background-color:#0E7490;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;DCL&lt;/div&gt;&lt;div style=&quot;font-size:10px;color:#0E7490;font-style:italic;margin-bottom:6px;&quot;&gt;Data Control&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 8px;font-family:monospace;font-size:9px;line-height:1.5;&quot;&gt;&lt;b&gt;GRANT SELECT&lt;/b&gt; ON products TO admin&lt;br&gt;&lt;b&gt;REVOKE DELETE&lt;/b&gt; ON users FROM clerk&lt;br&gt;&lt;br&gt;&lt;i&gt;Control de acceso: define qué rol puede leer/modificar cada tabla&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="320" x="720" y="2120" as="geometry" />
        </mxCell>
        <mxCell id="tcl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFFAFE;strokeColor=#0E7490;strokeWidth=2;align=center;verticalAlign=top;fontSize=11;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:16px;font-weight:bold;color:#FFFFFF;padding:8px;background-color:#0E7490;border-radius:4px 4px 0 0;margin:-8px -8px 8px -8px;&quot;&gt;TCL&lt;/div&gt;&lt;div style=&quot;font-size:10px;color:#0E7490;font-style:italic;margin-bottom:6px;&quot;&gt;Transaction Control&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 8px;font-family:monospace;font-size:9px;line-height:1.5;&quot;&gt;&lt;b&gt;BEGIN&lt;/b&gt; TRANSACTION&lt;br&gt;&lt;b&gt;COMMIT&lt;/b&gt; — confirma cambios&lt;br&gt;&lt;b&gt;ROLLBACK&lt;/b&gt; — revierte si falla&lt;br&gt;&lt;br&gt;&lt;i&gt;Garantiza ACID en compras: si falla pago, se revierte el descuento de stock&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="300" x="1060" y="2120" as="geometry" />
        </mxCell>
        <mxCell id="validacion" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAE8FF;strokeColor=#86198F;strokeWidth=2;align=center;verticalAlign=top;fontSize=11;fontColor=#1F2937;shadow=1;" value="&lt;div style=&quot;font-size:15px;font-weight:bold;color:#FFFFFF;padding:6px;background-color:#86198F;border-radius:4px 4px 0 0;margin:-8px -8px 10px -8px;&quot;&gt;✅ VALIDACIÓN DE TRANSACCIONES — Ejemplo: Compra de un Smartphone&lt;/div&gt;&lt;div style=&quot;text-align:left;padding:0 16px;font-family:monospace;font-size:11px;line-height:1.6;&quot;&gt;&lt;b style=&quot;color:#86198F;&quot;&gt;BEGIN TRANSACTION;&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;-- 1️⃣ Verificar stock disponible (consulta parametrizada)&lt;br&gt;&amp;nbsp;&amp;nbsp;SELECT stock FROM products WHERE id = ?;&lt;br&gt;&amp;nbsp;&amp;nbsp;-- 2️⃣ Descontar stock del producto&lt;br&gt;&amp;nbsp;&amp;nbsp;UPDATE products SET stock = stock - 1 WHERE id = ? AND stock &amp;gt; 0;&lt;br&gt;&amp;nbsp;&amp;nbsp;-- 3️⃣ Registrar la orden&lt;br&gt;&amp;nbsp;&amp;nbsp;INSERT INTO orders (user_id, total, fecha) VALUES (?, ?, NOW());&lt;br&gt;&amp;nbsp;&amp;nbsp;-- 4️⃣ Procesar pago vía pasarela (PCI-DSS)&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;b&gt;IF&lt;/b&gt; pago_exitoso &lt;b&gt;THEN&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;b style=&quot;color:#047857;&quot;&gt;COMMIT;&lt;/b&gt; &amp;nbsp;&amp;nbsp;-- ✅ Confirma compra y descuento de stock&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;b&gt;ELSE&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;b style=&quot;color:#DC2626;&quot;&gt;ROLLBACK;&lt;/b&gt; &amp;nbsp;-- ❌ Revierte TODOS los cambios (stock, orden)&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;b&gt;END IF;&lt;/b&gt;&lt;/div&gt;" vertex="1">
